rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return request.auth.token.role == 'admin'; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // /users/{uid}
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) &&
                       // parents can't change role/email/consent themselves
                       !(request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role', 'email', 'consentGivenAt']));
      allow create, delete: if isAdmin();

      // progress subcollection
      match /progress/{lessonId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }

      // user-earned badges
      match /userBadges/{badgeId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isAdmin(); // server-side via Admin SDK
      }
    }

    // Courses, lessons, activities — published-only for parents.
    match /courses/{courseId} {
      allow read: if (isSignedIn() && resource.data.isPublished == true) || isAdmin();
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if isSignedIn() || isAdmin();
        allow write: if isAdmin();
      }
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Submissions: parents create/read own, admins all
    match /submissions/{submissionId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Badges (catalog) — readable by all signed in, writable by admin
    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Batches — parents read own batch only
    match /batches/{batchId} {
      allow read: if (isSignedIn() && batchId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.batchId) || isAdmin();
      allow write: if isAdmin();
    }

    // Live classes — parents read for own batch only
    match /liveClasses/{classId} {
      allow read: if (isSignedIn() && resource.data.batchId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.batchId) || isAdmin();
      allow write: if isAdmin();
    }

    // Zara logs — parents create-only, admin read
    match /aiBuddyLogs/{logId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Leaderboard — denormalized projection, no PII
    // Cloud Function writes; everyone signed-in reads
    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // server-side only
    }
  }
}
